{
  "UserCache": {
    "SlidingExpirationHours": 5,
    "AbsoluteExpirationHours": 5,
    "Priority": "High"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "bdDevCRM.Presentation.AuthorizeAttributes": "Debug"
    },
    "StructuredLogging": {
      "Enabled": true,
      "LogRequestBody": true,
      "LogResponseBody": false,
      "MaxBodySize": 4096
    }
  },
  "PasswordHashing": {
    "BcryptWorkFactor": 14,
    "EnableAutoRehash": true,
    "EnableHashingLogs": true
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DbLocation": "",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "",
    "Audience": "",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7,
    "SecretKey": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:7145/",
      "https://localhost:7145/"
    ],
    "AllowCredentials": true,
    "PreflightMaxAge": 600
  },
  "TokenCleanup": {
    "IntervalHours": 24,
    "RetryDelayMinutes": 5
  },
  "AppSettings": {
    "controlPanelModuleId": 1
  },
  "Redis": {
    "Configuration": "localhost:7290",
    "InstanceName": "bdDevCRM:"
  },
  "CacheSettings": {
    "DefaultExpirationMinutes": 60,
    "EnableDistributedCache": false,
    "EnableL1Cache": true,
    "L1CacheSizeMB": 100,
    "CacheProfiles": {
      "Static": {
        "ExpirationHours": 24,
        "Priority": "High"
      },
      "User": {
        "ExpirationHours": 4,
        "Priority": "High"
      },
      "Dynamic": {
        "ExpirationMinutes": 15,
        "Priority": "Normal"
      },
      "Session": {
        "ExpirationMinutes": 30,
        "Priority": "High"
      }
    }
  },
  "ApplicationInsights": {
    "InstrumentationKey": "",
    "EnableAdaptiveSampling": true,
    "EnableQuickPulseMetricStream": true
  },
  "PerformanceMonitoring": {
    "SlowRequestThresholdMs": 1000,
    "VerySlowRequestThresholdMs": 5000,
    "SlowQueryThresholdMs": 500,
    "VerySlowQueryThresholdMs": 2000
  },
  "AuditLogging": {
    "EnableAuditMiddleware": true,
    "EnableEFCoreInterceptor": true,
    "QueueCapacity": 10000,
    "BatchSize": 100,
    "FlushIntervalSeconds": 5,
    "MaxBodyCaptureBytes": 4096,
    "SkipPaths": [
      "/health",
      "/swagger",
      "/uploads",
      "/_framework"
    ]
  },
  "ApiSettings": {
    "Version": "1.0",
    "EnableHATEOAS": false,
    "EnablePaginationLinks": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithCorrelationId"
    ]
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341",
    "ApiKey": ""
  }
}






